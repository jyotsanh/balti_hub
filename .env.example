BACKEND_CORS_ORIGINS=["http://localhost:4173","http://localhost:5173","http://localhost"]

# Project Setting
FIRST_SUPERUSER=balti@gmail.com
FIRST_SUPERUSER_PASSWORD=your-password-here
SECRET_KEY=change-me-to-a-strong-random-secret

# Production HOST & PORT
PROD_HOST=0.0.0.0
PROD_PORT=8015

# Development HOST & PORT
DEV_HOST=localhost
DEV_PORT=8015

# Redis (use Docker service name when running in containers)
REDIS_HOST=redis
REDIS_PORT=6379

# MongoDB (use Docker service name and INTERNAL port 27017, not host-mapped 27012)
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=balti-hub

### Frontend environment
# This is the URL the BROWSER uses to reach the backend (through host port mapping)
VITE_API_URL=http://localhost:8050/api/v1